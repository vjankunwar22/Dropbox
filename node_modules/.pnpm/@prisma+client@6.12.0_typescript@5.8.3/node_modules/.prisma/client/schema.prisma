datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  name         String?
  password     String
  profileImage String?
  role         UserRole        @default(USER)
  workspaces   WorkspaceUser[]
  files        File[]          @relation("OwnerFiles")
  invites      Invitation[]    @relation("InvitedUser")
  sharedFiles  FileShare[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  auditLogs    AuditLog[]

  // Reverse relations for createdBy/updatedBy
  workspaceCreatedBy     Workspace[]     @relation("WorkspaceCreatedBy")
  workspaceUpdatedBy     Workspace[]     @relation("WorkspaceUpdatedBy")
  workspaceUserCreatedBy WorkspaceUser[] @relation("WorkspaceUserCreatedBy")
  workspaceUserUpdatedBy WorkspaceUser[] @relation("WorkspaceUserUpdatedBy")
  inviteCreatedBy        Invitation[]    @relation("InviteCreatedBy")
  inviteUpdatedBy        Invitation[]    @relation("InviteUpdatedBy")
  fileCreatedBy          File[]          @relation("FileCreatedBy")
  fileUpdatedBy          File[]          @relation("FileUpdatedBy")
  fileShareCreatedBy     FileShare[]     @relation("FileShareCreatedBy")
  fileShareUpdatedBy     FileShare[]     @relation("FileShareUpdatedBy")
  fileContentCreatedBy   FileContent[]   @relation("FileContentCreatedBy")
  fileContentUpdatedBy   FileContent[]   @relation("FileContentUpdatedBy")
  auditLogCreatedBy      AuditLog[]      @relation("AuditLogCreatedBy")
  auditLogUpdatedBy      AuditLog[]      @relation("AuditLogUpdatedBy")
  tagCreatedBy           Tag[]           @relation("TagCreatedBy")
  tagUpdatedBy           Tag[]           @relation("TagUpdatedBy")
}

model Workspace {
  id          String          @id @default(uuid())
  slug        String          @unique
  name        String
  users       WorkspaceUser[]
  files       File[]
  invites     Invitation[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdById String
  createdBy   User            @relation("WorkspaceCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User            @relation("WorkspaceUpdatedBy", fields: [updatedById], references: [id])
}

model WorkspaceUser {
  id          String        @id @default(uuid())
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id])
  workspaceId String
  role        WorkspaceRole
  joinedAt    DateTime      @default(now())
  createdById String
  createdBy   User          @relation("WorkspaceUserCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User          @relation("WorkspaceUserUpdatedBy", fields: [updatedById], references: [id])

  @@unique([userId, workspaceId])
}

enum WorkspaceRole {
  ADMIN
  USER
}

model Invitation {
  id          String       @id @default(uuid())
  email       String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  workspaceId String
  invitedBy   User         @relation("InvitedUser", fields: [invitedById], references: [id])
  invitedById String
  status      InviteStatus
  createdAt   DateTime     @default(now())
  acceptedAt  DateTime?
  createdById String
  createdBy   User         @relation("InviteCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User         @relation("InviteUpdatedBy", fields: [updatedById], references: [id])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model File {
  id          String       @id @default(uuid())
  slug        String       @unique
  name        String
  description String?
  isFolder    Boolean      @default(false)
  parent      File?        @relation("ParentChild", fields: [parentId], references: [id])
  parentId    String?
  children    File[]       @relation("ParentChild")
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  workspaceId String
  owner       User         @relation("OwnerFiles", fields: [ownerId], references: [id])
  ownerId     String
  isPublic    Boolean      @default(false)
  shares      FileShare[]
  tags        FileTag[]
  content     FileContent?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdById String
  createdBy   User         @relation("FileCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User         @relation("FileUpdatedBy", fields: [updatedById], references: [id])
}

model FileShare {
  id          String   @id @default(uuid())
  file        File     @relation(fields: [fileId], references: [id])
  fileId      String
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("FileShareCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User     @relation("FileShareUpdatedBy", fields: [updatedById], references: [id])

  @@unique([fileId, userId])
}

model FileContent {
  id          String   @id @default(uuid())
  file        File     @relation(fields: [fileId], references: [id])
  fileId      String   @unique
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("FileContentCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User     @relation("FileContentUpdatedBy", fields: [updatedById], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  action      String
  entity      String
  entityId    String?
  details     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("AuditLogCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User     @relation("AuditLogUpdatedBy", fields: [updatedById], references: [id])
}

model Tag {
  id          String    @id @default(uuid())
  name        String    @unique
  files       FileTag[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String
  createdBy   User      @relation("TagCreatedBy", fields: [createdById], references: [id])
  updatedById String
  updatedBy   User      @relation("TagUpdatedBy", fields: [updatedById], references: [id])
}

model FileTag {
  id        String   @id @default(uuid())
  file      File     @relation(fields: [fileId], references: [id])
  fileId    String
  tag       Tag      @relation(fields: [tagId], references: [id])
  tagId     String
  createdAt DateTime @default(now())

  @@unique([fileId, tagId])
}

enum UserRole {
  USER
  ADMIN
}
